# Haven IAM — environment variables
# Copy to .env and fill in real values before starting.
# Generate secrets with: go run ./cmd/cli generate-secrets

# ── Server ────────────────────────────────────────────────────────────────────
HAVEN_PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# Individual components — Haven assembles the connection string.
HAVEN_DB_HOST=localhost
HAVEN_DB_PORT=5432
HAVEN_DB_USER=haven_app
HAVEN_DB_PASS=CHANGE_ME
HAVEN_DB_NAME=haven
# sslmode: use "disable" for local dev, "require" or "verify-full" in production.
HAVEN_DB_SSL_MODE=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
HAVEN_REDIS_ADDR=localhost:6379
HAVEN_REDIS_PASSWORD=

# ── JWT Signing Key ───────────────────────────────────────────────────────────
# 512-bit (64 bytes), hex-encoded. Fatal startup error if missing or < 32 bytes.
# Rotate with zero downtime: set new key as HAVEN_JWT_SIGNING_KEY and old key
# as HAVEN_JWT_SIGNING_KEY_PREV. Remove PREV after one access token lifetime (15 min).
HAVEN_JWT_SIGNING_KEY=CHANGE_ME_64_BYTES_HEX
HAVEN_JWT_SIGNING_KEY_PREV=

# ── Unattended Setup (CLI path only) ──────────────────────────────────────────
# Required only when running: haven-cli setup --unattended
# Leave blank for web UI wizard setup.
HAVEN_UNATTENDED=false
HAVEN_INSTANCE_NAME=
HAVEN_INSTANCE_TIMEZONE=UTC
HAVEN_INSTANCE_LOCALE=en-US
HAVEN_OWNER_EMAIL=
HAVEN_OWNER_NAME=
HAVEN_OWNER_PASSWORD=
HAVEN_SHARED_VAULT_NAME=
