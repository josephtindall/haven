# Ignore everything by default — only the file types listed below are tracked.
*

# Allow traversal into all directories
!*/
.idea/
.vscode/

# ── Tracked ───────────────────────────────────────────────────────────────────
!.gitignore
!*.go
!*.md
!*.yml
!*.yaml
!*.sql
!*.mod
!go.sum
!*.example
!Dockerfile*
!*.ps1
!.github/
!.gitkeep

# ── Ignored even if matched above ───────────────────────────────────────────
artifacts/*
!artifacts/.gitkeep